<!-- Start Hero Section -->
<section class="container py-5 bg-light mt-3" style="border-radius:25px; ">
    <div class="container">
        <div class="row align-items-center ps-2">
            <!-- Hero Text -->
            <div class="col-lg-8 col-md-12 text-center text-lg-start mb-3 mb-lg-0">
                <h1 class="display-5 fw-bold text-dark flex-wrap">Discover the Latest Fashion Trends</h1>
                <p class="lead text-muted mb-4">Shop high-quality clothing, accessories, and more at unbeatable prices. Elevate your style today!</p>
                <a href="#" class="btn btn-primary btn-lg rounded-3">Shop Now <i class="bi bi-arrow-right"></i></a>
            </div>
            <!-- Hero Image -->
            <div class="col-lg-4 col-md-12">
                <img src="/images/static/red polo.png" class="img-fluid rounded" style="max-height:500px;" alt="Hero Banner"> @* image size 600x400 *@
            </div>
        </div>
    </div>
</section>
<!-- End Hero Section -->
<!-- Start Promotional Banner Section -->
<section class="py-5">
    <div class="container">
        <div class="row g-4 position-relative">
            <!-- Left Promotional Banner -->
            <div class="col-lg-8 col-md-12">
                <div class="card border-0 rounded-4 shadow-sm" style="background: linear-gradient(90deg, #f8e1e1, #f5c6cb);">
                    <div class="row g-0 align-items-center">
                        <div class="col-md-6 p-4">
                            <h2 class="fw-bold text-dark">Spring Collection 2025</h2>
                            <p class="text-dark opacity-75">Explore our newest arrivals with up to 40% off. Don’t miss out!</p>
                            <a href="#" class="btn btn-dark rounded-3">Shop Collection <i class="bi bi-arrow-right"></i></a>
                        </div>
                        <div class="col-md-6">
                            <img src="https://via.placeholder.com/400x300" class="img-fluid rounded-end" alt="Spring Collection">
                        </div>
                    </div>
                </div>
            </div>
            <!-- Right Discount Highlight -->
            <div class="col-lg-4 col-md-12 position-relative">
                <div class="card border-0 rounded-4 shadow-sm text-center p-4" style="background: #e6f0fa;">
                    <h3 class="fw-bold text-primary">40% OFF</h3>
                    <p class="text-dark opacity-75">Limited Time Offer on Selected Items!</p>
                    <a href="#" class="btn btn-outline-primary rounded-3">Shop Deals</a>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- End Promotional Banner Section -->
<!-- Start Category Showcase Section -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center mb-4 fw-bold">Shop by Category</h2>
        <div class="row g-4">
            <!-- Category 1 -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm text-center">
                    <img src="https://via.placeholder.com/300x200" class="card-img-top rounded-top-4" alt="Men's Clothing">
                    <div class="card-body">
                        <h5 class="card-title fw-medium">Men's Clothing</h5>
                        <a href="#" class="btn btn-outline-primary btn-sm rounded-3">Explore</a>
                    </div>
                </div>
            </div>
            <!-- Category 2 -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm text-center">
                    <img src="https://via.placeholder.com/300x200" class="card-img-top rounded-top-4" alt="Women's Clothing">
                    <div class="card-body">
                        <h5 class="card-title fw-medium">Women's Clothing</h5>
                        <a href="#" class="btn btn-outline-primary btn-sm rounded-3">Explore</a>
                    </div>
                </div>
            </div>
            <!-- Category 3 -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm text-center">
                    <img src="https://via.placeholder.com/300x200" class="card-img-top rounded-top-4" alt="Accessories">
                    <div class="card-body">
                        <h5 class="card-title fw-medium">Accessories</h5>
                        <a href="#" class="btn btn-outline-primary btn-sm rounded-3">Explore</a>
                    </div>
                </div>
            </div>
            <!-- Category 4 -->
            <div class="col-lg-3 col-md-6 col-sm-6">
                <div class="card border-0 rounded-4 shadow-sm text-center">
                    <img src="https://via.placeholder.com/300x200" class="card-img-top rounded-top-4" alt="Footwear">
                    <div class="card-body">
                        <h5 class="card-title fw-medium">Footwear</h5>
                        <a href="#" class="btn btn-outline-primary btn-sm rounded-3">Explore</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- End Category Showcase Section -->
<!-- start Trending Products section -->
<section class="py-5">
    <div class="container section-title">
        <h2 class=" text-center mb-4 fw-bold">Trending Products</h2>
        <div class="row row-cols-1 row-cols-md-4 g-4">
            @foreach (var product in Model)
            {
                <div class="col-lg-3 col-sm-6">
                    <div class="row p-2">
                        <div class="col-12 p-1">
                            <a asp-action="Details" asp-route-ProductId="@product.Id" class="text-decoration-none">
                                <div class="card border-3 p-3 shadow rounded">
                                    @* border-top border-4  this if we want to add colored top border*@
                                    <div class="product-card">
                                        <img src="@product.ImageUrl" class="card-img-top img-fluid rounded">

                                    </div>
                                    <div class="card-body pb-0">
                                        <div>
                                            <h5 class="card-title text-dark text-uppercase fw-medium">@product.Name</h5>
                                            <p class="card-text text-dark">@product.Category.Name</p>
                                        </div>
                                        <div class="pl-1 pt-2 align-center">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <p class="text-black opacity-75 text-uppercase fw-bold">Price: <span>@product.Price.ToString("c")</span></p>
                                                <p class="text-dark opacity-75 text-decoration-line-through" style="font-size:14px;"><span>@product.ListPrice.ToString("c")</span></p>

                                            </div>
                                            @* if iwant to make btn add to cart uncomment and uncomment addtocart incontroller *@
@*                                             <form asp-action="AddToCart" method="post" class="d-grid">
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <button type="submit" class="btn btn-primary form-control">Add to Cart</button>
                                            </form> *@
                                            <a asp-action="Details" asp-route-ProductId="@product.Id" class="btn btn-primary form-control">Details</a>

                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
<!-- End Trending Products section -->