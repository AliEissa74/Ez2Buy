 @* @model IEnumerable<Ez2BuyWeb.ViewModels.ProductVM> *@
@model IEnumerable<Ez2Buy.DataAccess.Models.Product>

@{
	ViewData["title"] = "Product Page";
}

@* i added partial view for notification in _layout so we dont need to add it in each file *@

<div class="container mb-2">
	<div class="card shadow border-0 mt-4">
		<div class="card-header bg-secondary bg-gradient ml-0 py-3">
			<div class="row">
				<div class="col-12 text-center">
					<h2 class="text-white py-2">Product List</h2>
				</div>
			</div>
		</div>
		<div class="card-body p-4">
			<div class="row pb-3">

				<div class="col-6">
				</div>
				<div class="col-6 text-end">
					<a asp-controller="Product" asp-action="Create" class="btn rounded btn-primary p-2">
						<i class="bi bi-plus-circle fs-6"></i> Create New Product
					</a>
				</div>

			</div>
			<table id="tblData" class="table table-bordered table-striped datatbl">
				<thead>
					<tr>
						<th>Product Name</th>
						@* <th>Description</th> *@
						<th>List Price</th>
						<th>Price</th>
						<th>Category Name</th>
						<th></th>

					</tr>
				</thead>

			</table>
		</div>
	</div>
</div>
@section Scripts{
	<script src="~/js/product.js"></script>
}